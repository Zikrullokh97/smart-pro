generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id        String   @id @default(uuid())
  name      String
  nameKy    String?
  nameRu    String?
  nameUz    String?
  address   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students      Student[]
  teachers      Teacher[]
  classes       Class[]
  settings      SchoolSettings?
  auditLogs     AuditLog[]
  notifications Notification[]
  aiActions     AIAction[]
  attendances   Attendance[]
  grades        Grade[]
  homeworks     Homework[]
  schedules     Schedule[]
  reports       Report[]
  psychological Psychological[]
  health        Health[]
  discipline    Discipline[]
  aiRequests    AIRequest[]

  @@map("schools")
}

model SchoolSettings {
  id              String   @id @default(uuid())
  schoolId        String   @unique
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear    String
  currentTerm     Int      @default(1)
  maxStudentsPerClass Int   @default(30)
  gradingSystem   String   @default("5-point")
  defaultLanguage String   @default("kg")
  timezone        String   @default("Asia/Bishkek")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("school_settings")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles       UserRole[]
  auditLogs   AuditLog[]
  notifications Notification[]
  aiActions   AIAction[]
  teacher     Teacher?
  parent      Parent?
  student     Student?
  refreshTokens RefreshToken[]
  aiRequests  AIRequest[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  nameKy      String?
  nameRu      String?
  nameUz      String?
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  module      String
  action      String
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String    @id @default(uuid())
  roleId       String
  role         Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  scope     Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Student {
  id           String   @id @default(uuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId      String
  class        Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId       String?  @unique
  firstName    String
  lastName     String
  firstNameKy   String?
  lastNameKy    String?
  dateOfBirth  DateTime
  gender       String
  address      String?
  phone        String?
  email        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parents        StudentParent[]
  attendances    Attendance[]
  grades         Grade[]
  faceData       FaceData?
  psychological  Psychological[]
  health         Health[]
  discipline     Discipline[]
  classStudents  ClassStudent[]
  user           User?    @relation(fields: [userId], references: [id])

  @@map("students")
}

model Parent {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation String?
  workplace  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  children StudentParent[]

  @@map("parents")
}

model StudentParent {
  id           String   @id @default(uuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parentId     String
  parent       Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  relationship String
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([studentId, parentId])
  @@map("student_parents")
}

model Teacher {
  id           String   @id @default(uuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization String?
  qualification String?
  hireDate     DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  classes     Class[]
  attendances Attendance[]
  grades      Grade[]
  homeworks   Homework[]
  schedules   Schedule[]

  @@map("teachers")
}

model Class {
  id           String   @id @default(uuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name         String
  nameKy       String?
  nameRu       String?
  nameUz       String?
  grade        Int
  section      String
  classTeacherId String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students     ClassStudent[]
  studentList  Student[]
  attendances  Attendance[]
  grades       Grade[]
  homeworks    Homework[]
  schedule     Schedule[]
  teacher      Teacher? @relation(fields: [classTeacherId], references: [id])

  @@map("classes")
}

model ClassStudent {
  id        String   @id @default(uuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([classId, studentId])
  @@map("class_students")
}

model Attendance {
  id          String          @id @default(uuid())
  studentId   String
  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId     String
  class       Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     Teacher?        @relation(fields: [teacherId], references: [id])
  date        DateTime        @db.Date
  status      AttendanceStatus
  method      AttendanceMethod @default(MANUAL)
  recordedBy  String
  photoUrl    String?
  confidence  Float?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([studentId, classId, date])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AttendanceMethod {
  MANUAL
  FACE_RECOGNITION
  BIOMETRIC
  RFID
}

model Grade {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId   String
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id])
  value       Int
  maxValue    Int      @default(5)
  recordedBy  String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("grades")
}

model Homework {
  id          String   @id @default(uuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId   String
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id])
  title       String
  description String?
  dueDate     DateTime
  createdBy   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("homework")
}

model Schedule {
  id          String   @id @default(uuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startTime   DateTime
  endTime     DateTime
  subject     String
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  room        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("schedule")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Report {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  type        String
  data        Json
  generatedBy String
  createdAt   DateTime @default(now())

  @@map("reports")
}

model Psychological {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  notes       String
  recordedBy  String
  isConfidential Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("psychological")
}

model Health {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  condition   String
  notes       String?
  recordedBy  String
  isConfidential Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("health")
}

model Discipline {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  incident    String
  action      String
  notes       String?
  recordedBy  String
  isConfidential Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("discipline")
}

model FaceData {
  id             String   @id @default(uuid())
  studentId      String   @unique
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  photoUrl       String
  faceEmbedding  String?
  awsFaceId      String?
  confidence     Float?
  isActive       Boolean  @default(true)
  registeredAt   DateTime @default(now())
  registeredBy   String
  updatedAt      DateTime @updatedAt

  @@map("face_data")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  action      String
  module      String
  resourceId  String?
  details     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model AIAction {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  agentType   String
  actionType  String
  title       String
  description String?
  status      AIActionStatus @default(PENDING)
  data        Json?
  executedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ai_actions")
}

enum AIActionStatus {
  PENDING
  APPROVED
  REJECTED
  MODIFIED
  EXECUTED
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model AIRequest {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  agentType   String
  prompt      String
  response    String?
  tokensUsed  Int?
  createdAt   DateTime @default(now())

  @@map("ai_requests")
}